              "content": "<script>\n    (function() {\n        'use strict';\n\n        // Configurations\n        var targetUrls = [\n            'https://www.skoda.fr/promotions/promotion-detail/offre-fabia-clever-edition',\n            'https://www.skoda.fr/promotions/promotion-detail/offre-fabia',\n            'https://www.skoda.fr/gamme/fabia/fabia',\n            'https://www.skoda.fr/gamme/fabia/fabia-monte-carlo',\n            'https://www.skoda.fr/gamme/fabia/fabia-130',\n            'https://www.skoda.fr/promotions/promotion-detail/offre-kamiq-clever-edition',\n            'https://www.skoda.fr/promotions/promotion-detail/offre-kamiq',\n            'https://www.skoda.fr/gamme/kamiq/kamiq',\n            'https://www.skoda.fr/gamme/kamiq/kamiq-monte-carlo'\n        ];\n\n        var excludeSlugs = [\n            '/gamme/',\n            '/vehicules-occasion/',\n            '/services/reserver-essai-skoda'\n        ];\n\n        var formPageSlug = '/prendre-rendez-vous';\n\n        // State keys\n        var STATE_HAS_VISITED_FORM = '_skoda_ab_visited_form';\n        var STATE_TARGET_VISITED = '_skoda_ab_target_visited';\n        var STATE_PAGE_VIEWS = '_skoda_ab_page_views';\n        var STATE_POPIN_SHOWN = '_skoda_ab_popin_shown';\n        var STATE_TARGET_MODEL = '_skoda_ab_target_model';\n\n        // Fonction principale\n        function initPopinOffer() {\n            var currentUrl = window.location.href;\n\n            // 1. Track if user visits the form page\n            if (currentUrl.indexOf(formPageSlug) > -1) {\n                localStorage.setItem(STATE_HAS_VISITED_FORM, 'true');\n            }\n\n            // 2. Track if user visits a target URL\n            var isTargetUrl = false;\n            var visitedModel = '';\n            for (var i = 0; i < targetUrls.length; i++) {\n                if (currentUrl.indexOf(targetUrls[i]) > -1) {\n                    isTargetUrl = true;\n                    if (targetUrls[i].indexOf('kamiq') > -1) {\n                        visitedModel = 'kamiq';\n                    } else {\n                        visitedModel = 'fabia';\n                    }\n                    break;\n                }\n            }\n\n            if (isTargetUrl) {\n                localStorage.setItem(STATE_TARGET_VISITED, 'true');\n                if (visitedModel) {\n                    localStorage.setItem(STATE_TARGET_MODEL, visitedModel);\n                }\n                // Initialize or keep page views counter\n                if (!localStorage.getItem(STATE_PAGE_VIEWS)) {\n                    localStorage.setItem(STATE_PAGE_VIEWS, '0');\n                }\n            }\n\n            // 3. Increment page views if target was visited\n            if (localStorage.getItem(STATE_TARGET_VISITED) === 'true') {\n                var views = parseInt(localStorage.getItem(STATE_PAGE_VIEWS) || '0', 10);\n\n                // Adobe Target executes scripts on every page load\n                views++;\n                localStorage.setItem(STATE_PAGE_VIEWS, views.toString());\n\n                // 4. Check conditions to show popin (2 pages later)\n                if (views >= 3) {\n                    var hasVisitedForm = localStorage.getItem(STATE_HAS_VISITED_FORM) === 'true';\n                    var popinShown = localStorage.getItem(STATE_POPIN_SHOWN) === 'true';\n\n                    var isOnExcludedPage = false;\n                    for (var j = 0; j < excludeSlugs.length; j++) {\n                        if (currentUrl.indexOf(excludeSlugs[j]) > -1) {\n                            isOnExcludedPage = true;\n                            break;\n                        }\n                    }\n\n                    if (!hasVisitedForm && !popinShown && !isOnExcludedPage) {\n                        showPopin();\n                        localStorage.setItem(STATE_POPIN_SHOWN, 'true');\n                    }\n                }\n            }\n        }\n\n        function showPopin() {\n            var model = localStorage.getItem(STATE_TARGET_MODEL) || 'fabia';\n            var isKamiq = (model === 'kamiq');\n            var popinTitle = isKamiq ? \"Offre exclusive sur Škoda Kamiq\" : \"Offre exclusive sur Škoda Fabia\";\n            var ctaTarget = isKamiq ? \"https://www.skoda.fr/services/prendre-rendez-vous?model=NW4\" : \"https://www.skoda.fr/services/prendre-rendez-vous?model=PJ3\";\n            var imageUrl = isKamiq ?\n                \"https://cdn.skoda-auto.com/images/sites/frfr-v2/7dc838ca-4ef5-494b-823b-04ce11c69a8f/c72607456f242d677bbf8db51b54a469/HeroBannerModule/d5873a76116765a49a9393a5cabdf63b/6c15c19c9087422c4b3593b63bcd9cadee61d995aa9aa406ecd1beab812bc116/Header_bp1920_1.webp\" :\n                \"https://cdn.skoda-auto.com/images/sites/frfr-v2/8b94ce80-f794-40a0-b009-c7de106b4e0e/303767c923ec3ec4584db1c632edc0cb/HeroBannerModule/d5873a76116765a49a9393a5cabdf63b/6c15c19c9087422c4b3593b63bcd9cadee61d995aa9aa406ecd1beab812bc116/Header_bp1920_1.webp\";\n\n            var popinWrapper = document.createElement(\"div\");\n\n            var popinHTML = `\n            <div id=\"skoda-ab-popin-overlay\" class=\"is-active\">\n                <div id=\"skoda-ab-popin-modal\">\n                    <div class=\"popin-close\" id=\"popin-close-btn\" aria-label=\"Fermer\" onclick=\"document.getElementById('skoda-ab-popin-overlay').classList.remove('is-active');\"></div>\n                    <div class=\"popin-header\">\n                        <img alt=\"Image of selected model\" src=\"` + imageUrl + `\">\n                    </div>\n                    <div class=\"popin-body\">\n                        <div class=\"popin-title\">` + popinTitle + `</div>\n                        <div class=\"popin-text\">Vous avez jusqu'au 30 juin pour en profiter !</div>\n                        <a class=\"popin-cta\" tabindex=\"0\" target=\"_self\" href=\"` + ctaTarget + `\" title=\"Je prends rendez-vous\">\n                            Je prends rendez-vous\n                        </a>\n                    </div>\n                </div>\n            </div>\n        `;\n\n            popinWrapper.innerHTML = popinHTML;\n\n            var domBody = document.querySelector('body');\n            if (domBody) {\n                domBody.appendChild(popinWrapper);\n\n                window.dataLayer = window.dataLayer || [];\n                window.dataLayer.push({\n                    \"appweb.Name\": \"perso_experiment\",\n                    \"event\": \"trackEvent\",\n                    \"eventCategory\": \"AB - Popin \" + (isKamiq ? \"Kamiq\" : \"Fabia\"),\n                    \"eventAction\": \"displayed\",\n                    \"eventLabel\": \"variation\"\n                });\n            }\n        }\n      // tracking snippet\n    window.dataLayer = window.dataLayer || [];\n    var originalPush = window.dataLayer.push;\n    window.dataLayer.push = function() {\n        originalPush.apply(window.dataLayer, arguments);\n        var eventObj = arguments[0];\n        if (eventObj && \n            eventObj[\"appweb.Name\"] === \"form_submit\" && \n            eventObj.event === \"trackEvent\" && \n            eventObj.eventAction === \"ONELEAD_K2NG_Appointment_skoda_light\") {\n            \n            if (typeof adobe !== 'undefined' && adobe.target && typeof adobe.target.trackEvent === 'function') {\n                adobe.target.trackEvent({\n                    \"mbox\": \"click\",\n                    \"params\": {\n                        \"component\": \"Popin \" + isKamiq ? \"kamiq\" : \"Fabia\"\n                    }\n                });\n            }\n        }\n    };\n    // tracking snippet\n\n        // Lancer le script\n        if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', initPopinOffer);\n        } else {\n            initPopinOffer();\n        }\n    })();\n</script>\n\n<style>\n    #skoda-ab-popin-overlay {\n        position: fixed;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        background: rgba(0, 0, 0, 0.7);\n        backdrop-filter: blur(4px);\n        z-index: 999998;\n        opacity: 0;\n        transition: opacity 0.4s ease;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        pointer-events: none;\n    }\n\n    #skoda-ab-popin-overlay.is-active {\n        opacity: 1;\n        pointer-events: auto;\n    }\n\n    #skoda-ab-popin-modal {\n        background: #fff;\n        width: 90%;\n        max-width: 500px;\n        position: relative;\n        border-radius: 8px;\n        overflow: hidden;\n        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n        transform: translateY(20px);\n        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        font-family: 'Skoda Next', Arial, sans-serif;\n    }\n\n    #skoda-ab-popin-overlay.is-active #skoda-ab-popin-modal {\n        transform: translateY(0);\n    }\n\n    .popin-close {\n        position: absolute;\n        top: 15px;\n        right: 15px;\n        width: 30px;\n        height: 30px;\n        cursor: pointer;\n        z-index: 10;\n        background: rgba(255, 255, 255, 0.8);\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        transition: background 0.3s ease;\n    }\n\n    .popin-close:hover {\n        background: #fff;\n    }\n\n    .popin-close::before,\n    .popin-close::after {\n        content: '';\n        position: absolute;\n        width: 15px;\n        height: 2px;\n        background: #000;\n    }\n\n    .popin-close::before {\n        transform: rotate(45deg);\n    }\n\n    .popin-close::after {\n        transform: rotate(-45deg);\n    }\n\n    .popin-header img {\n        width: 100%;\n        height: auto;\n        display: block;\n    }\n\n    .popin-body {\n        padding: 30px;\n        text-align: center;\n    }\n\n    .popin-title {\n        font-size: 24px;\n        font-weight: bold;\n        margin-bottom: 15px;\n        color: #000;\n    }\n\n    .popin-text {\n        font-size: 16px;\n        color: #444;\n        line-height: 1.5;\n        margin-bottom: 25px;\n    }\n\n    .popin-cta {\n        display: inline-flex;\n        -webkit-box-align: center;\n        align-items: center;\n        -webkit-box-pack: center;\n        justify-content: center;\n        box-sizing: border-box;\n        -webkit-tap-highlight-color: transparent;\n        border: 0px;\n        margin: 0px;\n        cursor: pointer;\n        user-select: none;\n        vertical-align: middle;\n        appearance: none;\n        position: relative;\n        box-shadow: none;\n        text-rendering: geometricprecision;\n        outline: none;\n        min-width: 44px;\n        padding: 12px 24px;\n        flex-shrink: 0;\n        font-family: \"SKODA Next\", Arial, sans-serif;\n        letter-spacing: 0.75px;\n        text-transform: none;\n        text-decoration: none;\n        font-size: 16px;\n        font-weight: 700;\n        line-height: 16px;\n        background-clip: padding-box;\n        transition: transform 0.3s ease-out, color 0.3s ease-out, background-color 0.3s ease-out, border-color 0.3s ease-out, box-shadow 0.3s ease-out, opacity 0.3s ease-out;\n        border-radius: 1000px;\n        background-color: rgb(120, 250, 174);\n        color: rgb(22, 23, 24);\n        white-space: nowrap;\n        text-overflow: ellipsis;\n        overflow: hidden;\n    }\n\n    .popin-cta:hover {\n        transform: scale(1.02);\n        background-color: rgb(100, 230, 154);\n    }\n\n    @media (max-width: 600px) {\n        .popin-title {\n            font-size: 20px;\n        }\n\n        .popin-body {\n            padding: 20px;\n        }\n    }\n</style>"
